---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { GetStaticPaths } from 'astro';
import { type Locale, getMessages, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { getAllArtists, getArtistsByGenre } from '@/lib/data/artists';
import { genres } from '@/lib/data/genres';

export const getStaticPaths: GetStaticPaths = () => {
  return [
    { params: { locale: 'es' } },
    { params: { locale: 'de' } },
    { params: { locale: 'fr' } },
  ];
};

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale, 'artists');
const artists = getAllArtists();
---
<BaseLayout title={`${t('title')} | TuningFork`} description={t('description')} locale={locale}>
  <div class="container mx-auto px-4 py-6 sm:py-10">
    <!-- Header -->
    <header class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">
        {t('title')}
      </h1>
      <p class="text-text-secondary max-w-xl mx-auto">
        {t('description')}
      </p>
      <p class="text-sm text-primary-500 mt-2">
        {t('artistsCount', { count: artists.length })}
      </p>
    </header>

    <!-- Browse by Genre -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-white mb-4">{t('browseByGenre')}</h2>
      <div class="flex flex-wrap gap-3">
        {genres.map((genre) => {
          const genreArtists = getArtistsByGenre(genre.id);
          return (
            <a
              href={getLocalizedPath(`/browse/genre/${genre.slug}`, locale)}
              class="px-4 py-2 bg-tuner-card rounded-lg hover:bg-tuner-faded transition-colors"
            >
              <span class="text-white">{genre.name}</span>
              <span class="text-text-secondary ml-2 text-sm">
                ({genreArtists.length})
              </span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- All Artists by Genre -->
    {genres.map((genre) => {
      const genreArtists = getArtistsByGenre(genre.id);
      return (
        <section class="mb-10">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold text-white">{genre.name}</h2>
            <a
              href={getLocalizedPath(`/browse/genre/${genre.slug}`, locale)}
              class="text-sm text-primary-500 hover:text-primary-400"
            >
              {t('viewAll')}
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {genreArtists.map((artist) => {
              const primaryTuning = artist.primaryAppTuning?.name || artist.primaryTunings[0] || 'Standard';
              return (
                <a
                  href={getLocalizedPath(`/artists/${artist.slug}`, locale)}
                  class="group block bg-tuner-card rounded-lg p-4 hover:bg-tuner-faded transition-colors"
                >
                  <div class="flex flex-col h-full">
                    <h3 class="text-lg font-semibold text-white group-hover:text-primary-500 transition-colors">
                      {artist.name}
                    </h3>
                    {artist.band && (
                      <p class="text-sm text-text-secondary mt-0.5">{artist.band}</p>
                    )}
                    <div class="mt-3 flex flex-wrap gap-2">
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-primary-500/20 text-primary-400">
                        {primaryTuning}
                      </span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-tuner-faded text-text-secondary">
                        {artist.genre.name}
                      </span>
                    </div>
                    <p class="mt-3 text-sm text-text-secondary line-clamp-2 flex-grow">
                      {artist.stringGauge}
                    </p>
                    <div class="mt-3 text-xs text-text-secondary">
                      {artist.songs.length} songs
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
