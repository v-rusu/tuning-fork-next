---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { GetStaticPaths } from 'astro';
import { getMessages, useTranslations } from '@/i18n/utils';
import { InstrumentChordsPageIsland } from '@/components/pages/InstrumentChordsPageIsland';

export const getStaticPaths: GetStaticPaths = () => {
  return [
    { params: { instrument: 'guitar' } },
    { params: { instrument: 'ukulele' } },
  ];
};

const locale = 'en' as const;
const messages = getMessages(locale);
const { instrument: instrumentSlug } = Astro.params;
const tSeo = useTranslations(locale, 'seo');
const instrumentName = instrumentSlug === 'guitar' ? 'Guitar' : 'Ukulele';
const title = tSeo('chordsTitle', { instrument: instrumentName });
---
<BaseLayout title={`${title} | TuningFork`} locale={locale}>
  <InstrumentChordsPageIsland
    client:load
    instrumentSlug={instrumentSlug}
    locale={locale}
    messages={messages}
  />
</BaseLayout>
