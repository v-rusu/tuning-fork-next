---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getMessages } from '@/i18n/utils';
import { TunerPageIsland } from '@/components/pages/TunerPageIsland';

const locale = 'en' as const;
const messages = getMessages(locale);
---
<BaseLayout title="Chromatic Online Tuner | TuningFork" locale={locale}>
  <TunerPageIsland client:load messages={messages} />
</BaseLayout>
