---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { GetStaticPaths } from 'astro';
import { getMessages, useTranslations } from '@/i18n/utils';
import { referenceFrequencies, getFrequencyBySlug } from '@/lib/data/frequencies';
import { FrequencyPageIsland } from '@/components/pages/FrequencyPageIsland';

export const getStaticPaths: GetStaticPaths = () => {
  return referenceFrequencies.map((f) => ({ params: { frequency: f.slug } }));
};

const locale = 'en' as const;
const messages = getMessages(locale);
const { frequency: frequencySlug } = Astro.params;
const freq = getFrequencyBySlug(frequencySlug);
const tSeo = useTranslations(locale, 'seo');
const title = freq
  ? tSeo('tuningForkTitle', { frequency: String(freq.frequency) })
  : 'Tuning Fork | TuningFork';
---
<BaseLayout title={`${title} | TuningFork`} locale={locale}>
  <FrequencyPageIsland
    client:load
    frequencySlug={frequencySlug}
    locale={locale}
    messages={messages}
  />
</BaseLayout>
